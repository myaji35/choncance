<nav class="bg-white border-b border-slate-100 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-16">
      <!-- Logo -->
      <div class="flex items-center">
        <%= link_to root_path, class: "flex items-center gap-2 group" do %>
          <%= render "shared/icon", name: "leaf", size: 22, css: "text-green-700 group-hover:text-green-800 transition-colors" %>
          <span class="text-xl font-bold text-green-700 tracking-tight group-hover:text-green-800 transition-colors">ChonCance</span>
        <% end %>
        <div class="hidden sm:ml-10 sm:flex sm:items-center sm:space-x-1">
          <%= link_to properties_path, class: "flex items-center gap-1.5 text-slate-500 hover:text-slate-800 px-3 py-2 rounded-lg text-sm font-medium hover:bg-slate-50 transition-colors" do %>
            <%= render "shared/icon", name: "compass", size: 16 %>
            <span>테마 탐색</span>
          <% end %>
        </div>
      </div>

      <!-- Right Actions -->
      <div class="flex items-center gap-2">
        <% if authenticated? %>
          <%= link_to dashboard_path, class: "flex items-center gap-1.5 text-slate-500 hover:text-slate-800 px-3 py-2 rounded-lg text-sm font-medium hover:bg-slate-50 transition-colors" do %>
            <%= render "shared/icon", name: "user", size: 16 %>
            <span class="hidden sm:inline">대시보드</span>
          <% end %>
          <%= button_to session_path, method: :delete, class: "flex items-center gap-1.5 bg-slate-100 text-slate-600 px-4 py-2 rounded-xl text-sm font-medium hover:bg-slate-200 transition-colors cursor-pointer" do %>
            <%= render "shared/icon", name: "log-out", size: 16 %>
            <span class="hidden sm:inline">로그아웃</span>
          <% end %>
        <% else %>
          <%= link_to new_session_path, class: "flex items-center gap-1.5 text-slate-500 hover:text-slate-800 px-3 py-2 rounded-lg text-sm font-medium hover:bg-slate-50 transition-colors" do %>
            <%= render "shared/icon", name: "log-in", size: 16 %>
            <span>로그인</span>
          <% end %>
          <%= link_to "#", class: "flex items-center gap-1.5 bg-green-700 text-white px-4 py-2 rounded-xl text-sm font-semibold hover:bg-green-800 transition-colors shadow-sm" do %>
            <%= render "shared/icon", name: "user-plus", size: 16, css: "text-white" %>
            <span class="hidden sm:inline">가입하기</span>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</nav>
