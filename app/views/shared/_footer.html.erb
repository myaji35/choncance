<footer class="bg-slate-50 border-t border-slate-200 pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-16">
      <div class="md:col-span-2">
        <div class="flex items-center gap-2 mb-4">
          <%= render "shared/icon", name: "leaf", size: 20, css: "text-green-700" %>
          <span class="text-xl font-bold text-green-700">VINTEE</span>
        </div>
        <p class="text-slate-500 max-w-sm leading-relaxed text-sm">
          어촌과 농촌의 숨겨진 보석 같은 공간을 찾아 MZ세대에게 소개합니다.
          단순한 숙박을 넘어 호스트의 삶과 로컬의 이야기가 담긴 진짜 경험을 지향합니다.
        </p>
      </div>
      <div>
        <h4 class="text-xs font-bold text-slate-900 uppercase tracking-wider mb-4">서비스</h4>
        <ul class="space-y-2.5">
          <li>
            <%= link_to properties_path, class: "flex items-center gap-2 text-slate-500 hover:text-green-700 text-sm transition-colors" do %>
              <%= render "shared/icon", name: "compass", size: 13 %>
              숙소 탐색
            <% end %>
          </li>
          <li>
            <%= link_to "#", class: "flex items-center gap-2 text-slate-500 hover:text-green-700 text-sm transition-colors" do %>
              <%= render "shared/icon", name: "tag", size: 13 %>
              테마 큐레이션
            <% end %>
          </li>
          <li>
            <%= link_to "#", class: "flex items-center gap-2 text-slate-500 hover:text-green-700 text-sm transition-colors" do %>
              <%= render "shared/icon", name: "home", size: 13 %>
              호스트 신청
            <% end %>
          </li>
        </ul>
      </div>
      <div>
        <h4 class="text-xs font-bold text-slate-900 uppercase tracking-wider mb-4">고객지원</h4>
        <ul class="space-y-2.5">
          <li>
            <%= link_to "#", class: "flex items-center gap-2 text-slate-500 hover:text-green-700 text-sm transition-colors" do %>
              <%= render "shared/icon", name: "info", size: 13 %>
              자주 묻는 질문
            <% end %>
          </li>
          <li>
            <%= link_to "#", class: "flex items-center gap-2 text-slate-500 hover:text-green-700 text-sm transition-colors" do %>
              <%= render "shared/icon", name: "lock", size: 13 %>
              개인정보 처리방침
            <% end %>
          </li>
          <li>
            <%= link_to "#", class: "flex items-center gap-2 text-slate-500 hover:text-green-700 text-sm transition-colors" do %>
              <%= render "shared/icon", name: "list", size: 13 %>
              이용약관
            <% end %>
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-slate-200 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-slate-400 text-xs">© 2026 VINTEE. All rights reserved. Gagahoho, Inc.</p>
      <div class="flex items-center gap-4">
        <a href="#" class="text-slate-400 hover:text-slate-600 transition-colors" aria-label="Instagram">
          <%= render "shared/icon", name: "instagram", size: 18 %>
        </a>
        <a href="#" class="text-slate-400 hover:text-slate-600 transition-colors" aria-label="Facebook">
          <%= render "shared/icon", name: "facebook", size: 18 %>
        </a>
        <a href="#" class="text-slate-400 hover:text-slate-600 transition-colors" aria-label="YouTube">
          <%= render "shared/icon", name: "youtube", size: 18 %>
        </a>
      </div>
    </div>
  </div>
</footer>
