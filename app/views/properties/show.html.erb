<div class="bg-white min-h-screen">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Back Link -->
    <%= link_to properties_path, class: "inline-flex items-center gap-1.5 text-slate-500 hover:text-slate-700 text-sm font-medium mb-8 transition-colors" do %>
      <%= render "shared/icon", name: "arrow-left", size: 16 %>
      목록으로 돌아가기
    <% end %>

    <div class="lg:grid lg:grid-cols-3 lg:gap-12">
      <!-- Main Content -->
      <div class="lg:col-span-2">
        <div class="mb-8">
          <div class="flex flex-wrap gap-2 mb-4">
            <% @property.tags.each do |tag| %>
              <span class="inline-flex items-center gap-1.5 bg-slate-100 px-3 py-1.5 rounded-full text-xs font-bold text-slate-600">
                <%= render "shared/icon", name: tag_icon_name(tag.name), size: 11, css: "text-green-600" %>
                <%= tag.name %>
              </span>
            <% end %>
          </div>
          <h1 class="text-4xl font-extrabold text-slate-900 tracking-tight mb-4"><%= @property.title %></h1>
          <% if @property.respond_to?(:average_rating) && @property.average_rating %>
            <div class="flex items-center gap-1.5 mb-3">
              <span class="text-amber-400 text-sm">★</span>
              <span class="font-bold text-slate-900 text-sm"><%= @property.average_rating %></span>
              <span class="text-slate-400 text-sm">(<%= @property.reviews.count %>개 후기)</span>
            </div>
          <% end %>
          <div class="flex items-center gap-1.5 text-slate-500 font-medium">
            <%= render "shared/icon", name: "map-pin", size: 16, css: "text-green-600 shrink-0" %>
            <%= @property.location %>
          </div>
        </div>

        <!-- Gallery Placeholder -->
        <div class="aspect-video bg-slate-50 rounded-3xl mb-12 flex items-center justify-center border border-slate-100">
          <div class="text-center">
            <%= render "shared/icon", name: "camera", size: 48, css: "text-slate-200 mx-auto mb-3" %>
            <p class="font-medium text-slate-400 text-sm">고화질 감성 사진 갤러리 영역</p>
          </div>
        </div>

        <!-- Host Story -->
        <div>
          <div class="flex items-center gap-2 mb-6">
            <%= render "shared/icon", name: "feather", size: 20, css: "text-green-700" %>
            <h2 class="text-2xl font-bold text-slate-900">호스트 이야기</h2>
          </div>
          <div class="bg-green-50/60 p-8 rounded-3xl border border-green-100/80 mb-12">
            <p class="text-slate-700 text-lg leading-relaxed whitespace-pre-wrap"><%= @property.description %></p>
          </div>

          <div class="flex items-center gap-2 mb-4">
            <%= render "shared/icon", name: "sparkles", size: 18, css: "text-amber-500" %>
            <h3 class="text-xl font-bold text-slate-900">이곳에서의 경험</h3>
          </div>
          <ul class="grid grid-cols-1 md:grid-cols-2 gap-4 list-none p-0 mb-12">
            <li class="flex items-center gap-3 p-4 bg-slate-50 rounded-2xl border border-slate-100">
              <%= render "shared/icon", name: "coffee", size: 18, css: "text-amber-600 shrink-0" %>
              <span class="text-slate-700 font-medium">핸드드립 커피 체험</span>
            </li>
            <li class="flex items-center gap-3 p-4 bg-slate-50 rounded-2xl border border-slate-100">
              <%= render "shared/icon", name: "leaf", size: 18, css: "text-green-600 shrink-0" %>
              <span class="text-slate-700 font-medium">계절 농사 체험</span>
            </li>
          </ul>

          <!-- Honest Discomforts -->
          <div>
            <div class="flex items-center gap-2 mb-3">
              <%= render "shared/icon", name: "alert-circle", size: 18, css: "text-amber-500" %>
              <h3 class="text-xl font-bold text-slate-900">정직한 불편함</h3>
            </div>
            <p class="text-slate-500 text-sm mb-4 pl-6">VINTEE는 완벽함보다 진정성을 추구합니다. 아래 내용을 반드시 확인해주세요.</p>
            <div class="bg-amber-50 p-6 rounded-2xl border border-amber-100 text-amber-900 text-sm">
              <ul class="space-y-2.5">
                <% ["시골 특성상 작은 벌레가 출몰할 수 있습니다.",
                    "오래된 한옥이라 방음이 완벽하지 않을 수 있습니다.",
                    "마을 버스 배차 간격이 기니 자차 이용을 권장합니다."].each do |item| %>
                  <li class="flex items-start gap-2">
                    <%= render "shared/icon", name: "info", size: 14, css: "text-amber-600 shrink-0 mt-0.5" %>
                    <%= item %>
                  </li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>
      </div>

        <!-- Reviews Section -->
        <% if @property.respond_to?(:reviews) %>
          <div class="mt-12">
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-2">
                <%= render "shared/icon", name: "star", size: 20, css: "text-amber-400" %>
                <h2 class="text-2xl font-bold text-slate-900">
                  후기
                  <% if @property.average_rating %>
                    <span class="text-amber-500 ml-1"><%= @property.average_rating %></span>
                  <% end %>
                  <span class="text-slate-400 font-normal text-lg ml-1">(<%= @property.reviews.count %>)</span>
                </h2>
              </div>
              <% if defined?(Current) && Current.user.present? %>
                <%= link_to new_property_review_path(@property), class: "flex items-center gap-1.5 bg-green-700 text-white text-sm font-bold px-4 py-2 rounded-xl hover:bg-green-800 transition-colors" do %>
                  <%= render "shared/icon", name: "edit-2", size: 14, css: "text-white" %>
                  리뷰 작성
                <% end %>
              <% end %>
            </div>

            <% if @property.reviews.empty? %>
              <div class="bg-slate-50 rounded-3xl py-12 text-center border border-slate-100">
                <%= render "shared/icon", name: "star", size: 40, css: "text-slate-200 mx-auto mb-3" %>
                <p class="text-slate-400 font-medium text-sm">아직 후기가 없습니다.</p>
                <p class="text-slate-300 text-xs mt-1">첫 번째 후기를 남겨보세요!</p>
              </div>
            <% else %>
              <div class="bg-white border border-slate-200 rounded-3xl px-6">
                <% @property.reviews.recent.limit(10).each do |review| %>
                  <%= render "reviews/review", review: review %>
                <% end %>
              </div>
              <% if @property.reviews.count > 10 %>
                <div class="text-center mt-4">
                  <%= link_to property_reviews_path(@property), class: "inline-flex items-center gap-2 text-sm text-slate-500 hover:text-slate-800 font-semibold border border-slate-200 px-5 py-2.5 rounded-xl hover:bg-slate-50 transition-colors" do %>
                    더 보기 (<%= @property.reviews.count - 10 %>개)
                    <%= render "shared/icon", name: "chevron-down", size: 14 %>
                  <% end %>
                </div>
              <% end %>
            <% end %>
          </div>
        <% end %>

      <!-- Sidebar: Booking Card -->
      <div class="mt-12 lg:mt-0">
        <div class="sticky top-8 border border-slate-200 rounded-3xl p-8 shadow-xl bg-white">
          <div class="mb-8">
            <div class="flex items-baseline gap-1">
              <span class="text-3xl font-bold text-slate-900"><%= number_with_delimiter(@property.price_per_night) %>원</span>
              <span class="text-slate-500"> / 1박</span>
            </div>
            <div class="mt-2 flex items-center gap-1.5 text-sm">
              <%= render "shared/icon", name: "star", size: 14, css: "text-amber-400" %>
              <span class="font-bold text-slate-900">4.9</span>
              <span class="text-slate-400 font-normal">(후기 12개)</span>
            </div>
          </div>

          <div class="space-y-3 mb-8">
            <div class="grid grid-cols-2 border border-slate-200 rounded-2xl overflow-hidden">
              <div class="p-4 border-r border-slate-200">
                <div class="flex items-center gap-1 text-[10px] font-bold text-slate-700 uppercase mb-1">
                  <%= render "shared/icon", name: "calendar", size: 11 %>
                  체크인
                </div>
                <div class="text-sm font-medium text-slate-400">날짜 선택</div>
              </div>
              <div class="p-4">
                <div class="flex items-center gap-1 text-[10px] font-bold text-slate-700 uppercase mb-1">
                  <%= render "shared/icon", name: "calendar", size: 11 %>
                  체크아웃
                </div>
                <div class="text-sm font-medium text-slate-400">날짜 선택</div>
              </div>
            </div>
            <div class="p-4 border border-slate-200 rounded-2xl">
              <div class="flex items-center gap-1 text-[10px] font-bold text-slate-700 uppercase mb-1">
                <%= render "shared/icon", name: "user", size: 11 %>
                인원
              </div>
              <div class="text-sm font-medium text-slate-400">게스트 2명</div>
            </div>
          </div>

          <%= link_to "#", class: "flex items-center justify-center gap-2 w-full bg-green-700 text-white py-4 rounded-2xl font-bold shadow-lg hover:bg-green-800 transition transform active:scale-95" do %>
            <%= render "shared/icon", name: "calendar", size: 18, css: "text-white" %>
            예약 요청하기
          <% end %>

          <p class="flex items-center justify-center gap-1 text-slate-400 text-[11px] text-center mt-3">
            <%= render "shared/icon", name: "lock", size: 11, css: "text-slate-300" %>
            예약 확정 전에는 결제가 진행되지 않습니다.
          </p>

          <div class="mt-8 pt-6 border-t border-slate-100 flex items-center gap-4">
            <div class="w-12 h-12 bg-green-100 rounded-full flex items-center justify-center shrink-0">
              <%= render "shared/icon", name: "user", size: 22, css: "text-green-600" %>
            </div>
            <div>
              <div class="text-sm font-bold text-slate-900">슈퍼호스트 김영희님</div>
              <div class="flex items-center gap-1 text-xs text-slate-500">
                <%= render "shared/icon", name: "check-circle", size: 12, css: "text-green-500" %>
                응답률 100% · 24시간 내 응답
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
