<div class="bg-slate-50 min-h-screen py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12">
      <div>
        <h1 class="text-3xl font-bold text-slate-900 tracking-tight">촌캉스 탐색하기</h1>
        <p class="text-slate-500 mt-1">호스트의 진심이 담긴 공간들을 만나보세요.</p>
      </div>
      
      <div class="flex flex-wrap gap-2">
        <%= link_to "전체", properties_path, class: "px-4 py-2 rounded-xl text-sm font-medium #{params[:tag].blank? ? 'bg-green-700 text-white' : 'bg-white text-slate-600 border border-slate-200 hover:bg-slate-50'}" %>
        <% @tags.each do |tag| %>
          <%= link_to tag.name, properties_path(tag: tag.name), class: "px-4 py-2 rounded-xl text-sm font-medium #{params[:tag] == tag.name ? 'bg-green-700 text-white' : 'bg-white text-slate-600 border border-slate-200 hover:bg-slate-50'}" %>
        <% end %>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <% @properties.each do |property| %>
        <div class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-300 border border-slate-100 flex flex-col">
          <div class="aspect-video bg-slate-200 relative">
            <!-- Image placeholder -->
            <div class="absolute inset-0 flex items-center justify-center text-slate-400">
               <span class="text-4xl">🏡</span>
            </div>
            <% if property.tags.any? %>
              <div class="absolute top-4 left-4 flex gap-1">
                <% property.tags.take(2).each do |tag| %>
                  <span class="bg-white/90 backdrop-blur px-2 py-1 rounded-lg text-xs font-bold text-slate-700 shadow-sm"><%= tag.name %></span>
                <% end %>
              </div>
            <% end %>
          </div>
          
          <div class="p-6 flex-grow flex flex-col">
            <div class="text-xs font-bold text-green-700 mb-2"><%= property.location %></div>
            <h3 class="text-xl font-bold text-slate-900 mb-2"><%= link_to property.title, property_path(property), class: "hover:text-green-700" %></h3>
            <p class="text-slate-500 text-sm line-clamp-2 mb-6"><%= property.description %></p>
            
            <div class="mt-auto flex items-center justify-between">
              <div>
                <span class="text-lg font-bold text-slate-900"><%= number_with_delimiter(property.price_per_night) %>원</span>
                <span class="text-slate-400 text-sm"> / 1박</span>
              </div>
              <%= link_to "상세보기", property_path(property), class: "text-slate-900 text-sm font-bold border-b-2 border-green-700" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
