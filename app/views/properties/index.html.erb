<div class="bg-slate-50 min-h-screen py-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-12">
      <div>
        <div class="flex items-center gap-2 mb-1">
          <%= render "shared/icon", name: "compass", size: 22, css: "text-green-700" %>
          <h1 class="text-3xl font-bold text-slate-900 tracking-tight">촌캉스 탐색하기</h1>
        </div>
        <p class="text-slate-500 mt-1 pl-8">호스트의 진심이 담긴 공간들을 만나보세요.</p>
      </div>

      <!-- Tag Filters -->
      <div class="flex flex-wrap gap-2">
        <%= link_to properties_path, class: "flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-semibold transition-colors #{params[:tag].blank? ? 'bg-green-700 text-white shadow-sm' : 'bg-white text-slate-600 border border-slate-200 hover:bg-slate-50'}" do %>
          <%= render "shared/icon", name: "grid", size: 14, css: params[:tag].blank? ? "text-white" : "text-slate-500" %>
          전체
        <% end %>
        <% @tags.each do |tag| %>
          <%= link_to properties_path(tag: tag.name), class: "flex items-center gap-1.5 px-4 py-2 rounded-xl text-sm font-semibold transition-colors #{params[:tag] == tag.name ? 'bg-green-700 text-white shadow-sm' : 'bg-white text-slate-600 border border-slate-200 hover:bg-slate-50'}" do %>
            <%= render "shared/icon", name: tag_icon_name(tag.name), size: 14, css: params[:tag] == tag.name ? "text-white" : "text-slate-500" %>
            <%= tag.name %>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Property Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <% @properties.each do |property| %>
        <article class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition-shadow duration-300 border border-slate-100 flex flex-col group">
          <!-- Image Placeholder -->
          <div class="aspect-video bg-slate-50 relative flex items-center justify-center">
            <%= render "shared/icon", name: "image", size: 48, css: "text-slate-200" %>
            <% if property.tags.any? %>
              <div class="absolute top-4 left-4 flex gap-1.5">
                <% property.tags.take(2).each do |tag| %>
                  <span class="flex items-center gap-1 bg-white/90 backdrop-blur px-2.5 py-1 rounded-lg text-xs font-bold text-slate-700 shadow-sm">
                    <%= render "shared/icon", name: tag_icon_name(tag.name), size: 11, css: "text-green-600" %>
                    <%= tag.name %>
                  </span>
                <% end %>
              </div>
            <% end %>
          </div>

          <div class="p-6 flex-grow flex flex-col">
            <div class="flex items-center gap-1 text-xs font-bold text-green-700 mb-2">
              <%= render "shared/icon", name: "map-pin", size: 12, css: "text-green-600 shrink-0" %>
              <%= property.location %>
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-green-700 transition-colors">
              <%= link_to property.title, property_path(property), class: "hover:text-green-700" %>
            </h3>
            <p class="text-slate-500 text-sm line-clamp-2 mb-6"><%= property.description %></p>

            <div class="mt-auto flex items-center justify-between">
              <div>
                <span class="text-lg font-bold text-slate-900"><%= number_with_delimiter(property.price_per_night) %>원</span>
                <span class="text-slate-400 text-sm"> / 1박</span>
              </div>
              <%= link_to property_path(property), class: "flex items-center gap-1 text-sm font-bold text-slate-900 border-b-2 border-green-700 pb-0.5 hover:text-green-700 transition-colors" do %>
                상세보기
                <%= render "shared/icon", name: "arrow-right", size: 14 %>
              <% end %>
            </div>
          </div>
        </article>
      <% end %>
    </div>

    <% if @properties.empty? %>
      <div class="text-center py-24">
        <%= render "shared/icon", name: "search", size: 48, css: "text-slate-200 mx-auto mb-4" %>
        <p class="text-slate-400 font-medium">해당 조건의 숙소가 없습니다.</p>
        <%= link_to "전체 숙소 보기", properties_path, class: "inline-flex items-center gap-2 mt-4 text-green-700 font-bold hover:underline" do %>
          <%= render "shared/icon", name: "arrow-right", size: 16, css: "text-green-700" %>
          전체 숙소 보기
        <% end %>
      </div>
    <% end %>
  </div>
</div>
