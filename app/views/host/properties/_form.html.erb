<%= form_with model: [:host, property], class: "space-y-8" do |f| %>
  <% if property.errors.any? %>
    <div class="p-4 bg-rose-50 border border-rose-100 text-rose-700 text-sm rounded-2xl">
      <p class="font-bold mb-2">입력 오류를 확인해주세요:</p>
      <ul class="list-disc list-inside space-y-1">
        <% property.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- 기본 정보 -->
  <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm space-y-5">
    <h3 class="text-sm font-bold text-slate-900 flex items-center gap-2">
      <%= render "shared/icon", name: "home", size: 15, css: "text-green-700" %>
      기본 정보
    </h3>

    <div>
      <%= f.label :title, class: "block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2" do %>
        숙소 이름 <span class="text-rose-500">*</span>
      <% end %>
      <%= f.text_field :title, placeholder: "예: 제주 한달살기 감성 돌담집",
          class: "w-full px-4 py-3 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition" %>
    </div>

    <div>
      <%= f.label :location, class: "block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2" do %>
        위치
      <% end %>
      <%= f.text_field :location, placeholder: "예: 전남 담양군 창평면",
          class: "w-full px-4 py-3 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition" %>
    </div>

    <div>
      <%= f.label :description, class: "block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2" do %>
        숙소 소개
      <% end %>
      <%= f.text_area :description, rows: 5, placeholder: "숙소와 주변 환경, 호스트의 이야기를 자유롭게 적어주세요.",
          class: "w-full px-4 py-3 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition resize-none" %>
    </div>
  </div>

  <!-- 가격 및 상태 -->
  <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm space-y-5">
    <h3 class="text-sm font-bold text-slate-900 flex items-center gap-2">
      <%= render "shared/icon", name: "tag", size: 15, css: "text-green-700" %>
      가격 및 공개 설정
    </h3>

    <div>
      <%= f.label :price_per_night, class: "block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2" do %>
        1박 가격 (원) <span class="text-rose-500">*</span>
      <% end %>
      <%= f.number_field :price_per_night, placeholder: "150000",
          class: "w-full px-4 py-3 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-green-500 transition" %>
    </div>

    <div>
      <%= f.label :status, class: "block text-xs font-bold text-slate-700 uppercase tracking-widest mb-2" %>
      <div class="flex gap-3">
        <label class="flex items-center gap-2 cursor-pointer">
          <%= f.radio_button :status, "draft", class: "text-green-700 focus:ring-green-500" %>
          <span class="text-sm text-slate-700 font-medium">임시저장</span>
        </label>
        <label class="flex items-center gap-2 cursor-pointer">
          <%= f.radio_button :status, "active", class: "text-green-700 focus:ring-green-500" %>
          <span class="text-sm text-slate-700 font-medium">즉시 공개</span>
        </label>
      </div>
    </div>
  </div>

  <!-- 태그 선택 -->
  <% if @tags.present? %>
    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
      <h3 class="text-sm font-bold text-slate-900 flex items-center gap-2 mb-4">
        <%= render "shared/icon", name: "hash", size: 15, css: "text-green-700" %>
        테마 태그
      </h3>
      <div class="flex flex-wrap gap-2">
        <% @tags.each do |tag| %>
          <label class="cursor-pointer">
            <input type="checkbox" name="property[tag_ids][]" value="<%= tag.id %>"
                   <%= "checked" if property.tags.include?(tag) %>
                   class="sr-only peer">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-semibold border border-slate-200 text-slate-500 peer-checked:bg-green-700 peer-checked:text-white peer-checked:border-green-700 transition-all cursor-pointer hover:border-green-400">
              #<%= tag.name %>
            </span>
          </label>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Submit -->
  <div class="flex items-center gap-3">
    <%= f.submit property.new_record? ? "숙소 등록하기" : "수정 저장하기",
        class: "flex-1 sm:flex-none px-8 py-3.5 bg-green-700 text-white text-sm font-bold rounded-xl hover:bg-green-800 transition-colors shadow-sm cursor-pointer" %>
    <%= link_to "취소", host_dashboard_path,
        class: "flex-1 sm:flex-none px-8 py-3.5 bg-slate-100 text-slate-600 text-sm font-bold rounded-xl hover:bg-slate-200 transition-colors text-center" %>
  </div>
<% end %>
