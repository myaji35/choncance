<div class="bg-slate-50 min-h-screen py-10">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="mb-8 flex items-center gap-3">
      <%= link_to host_dashboard_path, class: "p-2 text-slate-400 hover:text-slate-700 hover:bg-white rounded-xl transition-colors border border-slate-200" do %>
        <%= render "shared/icon", name: "arrow-left", size: 16 %>
      <% end %>
      <div>
        <h1 class="text-xl font-bold text-slate-900">숙소 수정</h1>
        <p class="text-slate-400 text-sm mt-0.5 truncate"><%= @property.title %></p>
      </div>
    </div>
    <%= render "form", property: @property %>
  </div>
</div>
