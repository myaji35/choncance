<div class="bg-slate-50 min-h-screen py-10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="mb-10 flex items-center justify-between">
      <div>
        <h1 class="text-2xl font-bold text-slate-900 tracking-tight">호스트 대시보드</h1>
        <p class="text-slate-500 text-sm mt-1 flex items-center gap-1.5">
          <%= render "shared/icon", name: "user", size: 13, css: "text-slate-400" %>
          <%= Current.user.email_address %>
        </p>
      </div>
      <%= link_to new_host_property_path, class: "flex items-center gap-2 bg-green-700 text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-green-800 transition-colors shadow-sm" do %>
        <%= render "shared/icon", name: "plus", size: 16, css: "text-white" %>
        숙소 등록
      <% end %>
    </div>

    <% if notice %>
      <div class="mb-6 flex items-center gap-3 p-4 bg-green-50 border border-green-100 text-green-700 text-sm rounded-2xl">
        <%= render "shared/icon", name: "check-circle", size: 16, css: "text-green-500 shrink-0" %>
        <%= notice %>
      </div>
    <% end %>

    <!-- KPI Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5 mb-10">
      <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <%= render "shared/icon", name: "home", size: 18, css: "text-slate-400" %>
          <span class="text-xs font-bold text-slate-500 uppercase tracking-widest">전체 숙소</span>
        </div>
        <p class="text-3xl font-bold text-slate-900"><%= @total_properties %></p>
      </div>
      <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <%= render "shared/icon", name: "check-circle", size: 18, css: "text-green-500" %>
          <span class="text-xs font-bold text-slate-500 uppercase tracking-widest">활성 숙소</span>
        </div>
        <p class="text-3xl font-bold text-green-700"><%= @active_properties %></p>
      </div>
      <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
        <div class="flex items-center gap-3 mb-3">
          <%= render "shared/icon", name: "edit-3", size: 18, css: "text-amber-400" %>
          <span class="text-xs font-bold text-slate-500 uppercase tracking-widest">임시저장</span>
        </div>
        <p class="text-3xl font-bold text-amber-500"><%= @draft_properties %></p>
      </div>
    </div>

    <!-- Pending Review Section (자동 수집 숙소 승인 대기) -->
    <% if @pending_review.any? %>
      <div class="mb-8 bg-amber-50 border border-amber-200 rounded-3xl overflow-hidden shadow-sm">
        <div class="px-6 py-4 border-b border-amber-100 flex items-center gap-3">
          <%= render "shared/icon", name: "alert-triangle", size: 16, css: "text-amber-500 shrink-0" %>
          <h2 class="text-sm font-bold text-amber-800">
            파트너 숙소 검토 대기 (<%= @pending_review.count %>건)
          </h2>
          <span class="ml-auto text-xs text-amber-600">승인하면 탐색 페이지에 노출됩니다</span>
        </div>
        <div class="divide-y divide-amber-100">
          <% @pending_review.limit(10).each do |property| %>
            <div class="flex items-center gap-4 px-6 py-4 hover:bg-amber-100/40 transition-colors">
              <!-- Thumbnail -->
              <div class="w-14 h-14 bg-amber-100 rounded-xl flex items-center justify-center shrink-0 overflow-hidden">
                <% if property.thumbnail_url.present? %>
                  <img src="<%= property.thumbnail_url %>" alt="<%= property.title %>" class="w-full h-full object-cover" loading="lazy">
                <% else %>
                  <%= render "shared/icon", name: "image", size: 22, css: "text-amber-300" %>
                <% end %>
              </div>
              <!-- Info -->
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-slate-900 truncate"><%= property.title %></p>
                <p class="flex items-center gap-1 text-xs text-slate-500 mt-0.5">
                  <%= render "shared/icon", name: "map-pin", size: 11 %>
                  <%= property.location.presence || property.address.presence || "위치 미설정" %>
                </p>
                <p class="text-xs text-amber-600 mt-0.5">
                  출처: <%= property.uploaded_by %>
                </p>
              </div>
              <!-- Actions -->
              <div class="flex items-center gap-2 shrink-0">
                <%= button_to approve_host_property_path(property), method: :patch,
                    data: { confirm: "\"#{property.title}\" 숙소를 승인하시겠습니까?" },
                    class: "flex items-center gap-1.5 bg-green-600 text-white text-xs font-bold px-3 py-2 rounded-xl hover:bg-green-700 transition-colors cursor-pointer" do %>
                  <%= render "shared/icon", name: "check", size: 13, css: "text-white" %>
                  승인
                <% end %>
                <%= button_to reject_host_property_path(property), method: :delete,
                    data: { confirm: "\"#{property.title}\" 숙소를 거부하고 삭제하시겠습니까?" },
                    class: "flex items-center gap-1.5 bg-white border border-rose-200 text-rose-500 text-xs font-bold px-3 py-2 rounded-xl hover:bg-rose-50 transition-colors cursor-pointer" do %>
                  <%= render "shared/icon", name: "x", size: 13, css: "text-rose-500" %>
                  거부
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
        <% if @pending_review.count > 10 %>
          <div class="px-6 py-3 border-t border-amber-100 text-center">
            <%= link_to host_properties_path, class: "text-xs text-amber-600 hover:text-amber-800 font-semibold" do %>
              나머지 <%= @pending_review.count - 10 %>건 더 보기 →
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Properties Table -->
    <div class="bg-white border border-slate-200 rounded-3xl shadow-sm overflow-hidden">
      <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between">
        <h2 class="text-base font-bold text-slate-900 flex items-center gap-2">
          <%= render "shared/icon", name: "list", size: 16, css: "text-slate-400" %>
          내 숙소 목록
        </h2>
        <%= link_to host_properties_path, class: "text-xs text-slate-400 hover:text-slate-700 transition-colors" do %>
          전체보기
        <% end %>
      </div>

      <% if @properties.empty? %>
        <div class="py-20 text-center">
          <%= render "shared/icon", name: "inbox", size: 48, css: "text-slate-200 mx-auto mb-4" %>
          <p class="text-slate-400 font-medium text-sm">등록된 숙소가 없습니다.</p>
          <%= link_to new_host_property_path, class: "inline-flex items-center gap-2 mt-6 bg-green-700 text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-green-800 transition-colors" do %>
            <%= render "shared/icon", name: "plus", size: 14, css: "text-white" %>
            첫 숙소 등록하기
          <% end %>
        </div>
      <% else %>
        <div class="divide-y divide-slate-100">
          <% @properties.each do |property| %>
            <div class="flex items-center gap-4 px-6 py-4 hover:bg-slate-50 transition-colors">
              <!-- Thumbnail placeholder -->
              <div class="w-14 h-14 bg-slate-100 rounded-xl flex items-center justify-center shrink-0">
                <%= render "shared/icon", name: "image", size: 22, css: "text-slate-300" %>
              </div>
              <!-- Info -->
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-slate-900 truncate"><%= property.title %></p>
                <p class="flex items-center gap-1 text-xs text-slate-400 mt-0.5">
                  <%= render "shared/icon", name: "map-pin", size: 11 %>
                  <%= property.location.presence || "위치 미설정" %>
                </p>
              </div>
              <!-- Price -->
              <div class="hidden sm:block text-right shrink-0">
                <p class="text-sm font-bold text-slate-900"><%= number_to_currency(property.price_per_night, unit: "₩", precision: 0, delimiter: ",") %></p>
                <p class="text-xs text-slate-400">/ 1박</p>
              </div>
              <!-- Status badge -->
              <div class="shrink-0">
                <% if property.active? %>
                  <span class="inline-flex items-center gap-1 bg-green-50 text-green-700 text-xs font-bold px-2.5 py-1 rounded-full">
                    <%= render "shared/icon", name: "check", size: 11 %>
                    활성
                  </span>
                <% elsif property.draft? %>
                  <span class="inline-flex items-center gap-1 bg-amber-50 text-amber-600 text-xs font-bold px-2.5 py-1 rounded-full">
                    <%= render "shared/icon", name: "edit-3", size: 11 %>
                    임시저장
                  </span>
                <% else %>
                  <span class="inline-flex items-center gap-1 bg-slate-100 text-slate-500 text-xs font-bold px-2.5 py-1 rounded-full">
                    보관됨
                  </span>
                <% end %>
              </div>
              <!-- Actions -->
              <div class="flex items-center gap-2 shrink-0">
                <%= link_to edit_host_property_path(property), class: "p-2 text-slate-400 hover:text-slate-700 hover:bg-slate-100 rounded-lg transition-colors" do %>
                  <%= render "shared/icon", name: "edit-2", size: 15 %>
                <% end %>
                <%= button_to host_property_path(property), method: :delete,
                    data: { confirm: "\"#{property.title}\" 숙소를 삭제하시겠습니까?" },
                    class: "p-2 text-slate-400 hover:text-rose-600 hover:bg-rose-50 rounded-lg transition-colors cursor-pointer" do %>
                  <%= render "shared/icon", name: "trash-2", size: 15 %>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

  </div>

  <!-- Reviews Section: Awaiting Host Reply -->
  <% unanswered_reviews = Review.joins(:property).where(properties: { id: @properties.pluck(:id) }).where(host_reply: [nil, ""]).order(created_at: :desc).limit(10) %>
  <% if unanswered_reviews.any? %>
    <div class="mt-8 bg-white rounded-3xl border border-amber-200 overflow-hidden">
      <div class="flex items-center justify-between px-6 py-5 border-b border-amber-100 bg-amber-50/50">
        <div class="flex items-center gap-2">
          <%= render "shared/icon", name: "message-circle", size: 20, css: "text-amber-500" %>
          <h2 class="text-lg font-bold text-slate-900">답글 대기 중인 리뷰</h2>
          <span class="ml-1 bg-amber-100 text-amber-700 text-xs font-bold px-2 py-0.5 rounded-full"><%= unanswered_reviews.count %>건</span>
        </div>
      </div>
      <div class="divide-y divide-slate-100">
        <% unanswered_reviews.each do |review| %>
          <div class="px-6 py-5">
            <div class="flex items-start justify-between gap-4 mb-3">
              <div class="flex items-start gap-3">
                <div class="w-9 h-9 bg-green-100 rounded-full flex items-center justify-center shrink-0 mt-0.5">
                  <span class="text-green-700 font-bold text-sm"><%= review.user.email_address[0].upcase %></span>
                </div>
                <div>
                  <div class="flex items-center gap-2 mb-1">
                    <span class="font-semibold text-slate-800 text-sm">
                      <% eu = review.user.email_address.split('@').first %>
                      <%= eu.length > 2 ? "#{eu[0]}#{'*' * (eu.length - 2)}#{eu[-1]}" : eu %>
                    </span>
                    <span class="text-xs text-slate-400">·</span>
                    <span class="text-xs text-slate-400"><%= review.created_at.strftime("%Y.%m.%d") %></span>
                    <span class="inline-flex items-center gap-0.5">
                      <% 5.times do |i| %>
                        <span class="text-xs <%= i < review.rating ? 'text-amber-400' : 'text-slate-200' %>">★</span>
                      <% end %>
                    </span>
                  </div>
                  <p class="text-sm text-slate-600 mb-1"><%= review.property.title %></p>
                  <p class="text-sm text-slate-700 leading-relaxed"><%= review.comment %></p>
                </div>
              </div>
            </div>
            <!-- Reply Form -->
            <%= form_with url: reply_host_review_path(review), method: :patch, class: "ml-12" do |f| %>
              <div class="flex gap-2 mt-3">
                <%= f.text_area :host_reply,
                    rows: 2,
                    placeholder: "게스트에게 감사의 답글을 남겨보세요...",
                    class: "flex-1 border border-slate-200 rounded-xl px-3 py-2 text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent resize-none",
                    required: true %>
                <%= f.submit "답글 등록",
                    class: "shrink-0 bg-green-700 text-white text-sm font-bold px-4 py-2 rounded-xl hover:bg-green-800 transition-colors cursor-pointer self-end" %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
