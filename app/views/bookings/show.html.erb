<div class="bg-slate-50 min-h-screen py-12">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Back Link -->
    <div class="mb-6">
      <%= link_to bookings_path, class: "inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-800 font-medium transition-colors" do %>
        <%= render "shared/icon", name: "arrow-left", size: 16 %>
        예약 내역으로 돌아가기
      <% end %>
    </div>

    <% if notice.present? %>
      <div class="mb-6 flex items-center gap-3 p-4 bg-green-50 border border-green-100 text-green-700 text-sm rounded-2xl">
        <%= render "shared/icon", name: "check-circle", size: 16, css: "text-green-500 shrink-0" %>
        <%= notice %>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="mb-6 flex items-center gap-3 p-4 bg-red-50 border border-red-100 text-red-700 text-sm rounded-2xl">
        <%= render "shared/icon", name: "alert-circle", size: 16, css: "text-red-500 shrink-0" %>
        <%= alert %>
      </div>
    <% end %>

    <!-- Booking Detail Card -->
    <div class="bg-white border border-slate-200 rounded-3xl shadow-sm overflow-hidden">

      <!-- Header -->
      <div class="px-8 py-6 border-b border-slate-100 flex items-center justify-between">
        <div>
          <h1 class="text-xl font-bold text-slate-900">예약 상세</h1>
          <p class="text-xs text-slate-400 mt-1">예약번호: #<%= @booking.id %></p>
        </div>
        <% if @booking.status == "confirmed" %>
          <span class="inline-flex items-center gap-1.5 bg-green-50 text-green-700 text-sm font-bold px-4 py-2 rounded-full">
            <%= render "shared/icon", name: "check-circle", size: 14 %>
            예약 확정
          </span>
        <% elsif @booking.status.start_with?("cancelled") %>
          <span class="inline-flex items-center gap-1.5 bg-red-50 text-red-500 text-sm font-bold px-4 py-2 rounded-full">
            <%= render "shared/icon", name: "x", size: 14 %>
            <%= @booking.status_label %>
          </span>
        <% else %>
          <span class="inline-flex items-center gap-1.5 bg-slate-50 text-slate-500 text-sm font-bold px-4 py-2 rounded-full">
            <%= @booking.status_label %>
          </span>
        <% end %>
      </div>

      <!-- Property Info -->
      <div class="px-8 py-6 border-b border-slate-100">
        <div class="flex items-start gap-5">
          <div class="w-20 h-20 bg-slate-100 rounded-2xl flex items-center justify-center shrink-0">
            <% if @booking.property.thumbnail_url.present? %>
              <img src="<%= @booking.property.thumbnail_url %>" alt="<%= @booking.property.title %>"
                   class="w-full h-full object-cover rounded-2xl" loading="lazy">
            <% else %>
              <%= render "shared/icon", name: "image", size: 28, css: "text-slate-300" %>
            <% end %>
          </div>
          <div class="flex-1">
            <h2 class="text-lg font-bold text-slate-900">
              <%= link_to @booking.property.title, property_path(@booking.property),
                  class: "hover:text-green-700 transition-colors" %>
            </h2>
            <p class="flex items-center gap-1 text-sm text-slate-500 mt-1">
              <%= render "shared/icon", name: "map-pin", size: 13, css: "text-slate-400 shrink-0" %>
              <%= @booking.property.location.presence || "위치 미설정" %>
            </p>
          </div>
        </div>
      </div>

      <!-- Booking Details -->
      <div class="px-8 py-6 border-b border-slate-100">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
          <div>
            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">체크인</p>
            <p class="text-base font-bold text-slate-900"><%= @booking.check_in.strftime("%Y.%m.%d") %></p>
          </div>
          <div>
            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">체크아웃</p>
            <p class="text-base font-bold text-slate-900"><%= @booking.check_out.strftime("%Y.%m.%d") %></p>
          </div>
          <div>
            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">숙박</p>
            <p class="text-base font-bold text-slate-900"><%= @booking.nights %>박</p>
          </div>
          <div>
            <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-1">인원</p>
            <p class="text-base font-bold text-slate-900"><%= @booking.guest_count %>명</p>
          </div>
        </div>
      </div>

      <!-- Price Summary -->
      <div class="px-8 py-6 border-b border-slate-100">
        <div class="flex items-center justify-between">
          <span class="text-sm text-slate-500">총 결제 금액</span>
          <span class="text-2xl font-bold text-slate-900"><%= number_with_delimiter(@booking.total_price) %>원</span>
        </div>
      </div>

      <!-- Cancellation Section -->
      <% if @booking.cancellable? %>
        <div class="px-8 py-6 bg-slate-50">
          <h3 class="flex items-center gap-2 text-sm font-bold text-slate-700 mb-4">
            <%= render "shared/icon", name: "info", size: 14, css: "text-slate-400" %>
            취소 및 환불 정책
          </h3>

          <!-- Policy Steps -->
          <div class="bg-white border border-slate-200 rounded-2xl p-5 mb-5">
            <div class="space-y-3 text-sm">
              <div class="flex items-center gap-3 <%= @booking.refund_percentage == 100 ? 'text-green-700 font-bold' : 'text-slate-400' %>">
                <div class="w-6 h-6 rounded-full flex items-center justify-center shrink-0 <%= @booking.refund_percentage == 100 ? 'bg-green-100' : 'bg-slate-100' %>">
                  <%= render "shared/icon", name: "check", size: 12, css: @booking.refund_percentage == 100 ? "text-green-600" : "text-slate-300" %>
                </div>
                7일 이상 전 취소: 100% 환불
              </div>
              <div class="flex items-center gap-3 <%= @booking.refund_percentage == 50 ? 'text-amber-700 font-bold' : 'text-slate-400' %>">
                <div class="w-6 h-6 rounded-full flex items-center justify-center shrink-0 <%= @booking.refund_percentage == 50 ? 'bg-amber-100' : 'bg-slate-100' %>">
                  <%= render "shared/icon", name: "check", size: 12, css: @booking.refund_percentage == 50 ? "text-amber-500" : "text-slate-300" %>
                </div>
                3~6일 전 취소: 50% 환불
              </div>
              <div class="flex items-center gap-3 <%= @booking.refund_percentage == 0 ? 'text-red-600 font-bold' : 'text-slate-400' %>">
                <div class="w-6 h-6 rounded-full flex items-center justify-center shrink-0 <%= @booking.refund_percentage == 0 ? 'bg-red-100' : 'bg-slate-100' %>">
                  <%= render "shared/icon", name: "x", size: 12, css: @booking.refund_percentage == 0 ? "text-red-500" : "text-slate-300" %>
                </div>
                3일 미만: 환불 불가
              </div>
            </div>
          </div>

          <!-- Refund Summary -->
          <div class="bg-white border border-slate-200 rounded-2xl p-5 mb-5">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm text-slate-500">현재 적용 정책</span>
              <span class="text-sm font-bold text-slate-900"><%= @booking.cancellation_policy_label %></span>
            </div>
            <div class="flex items-center justify-between">
              <span class="text-sm text-slate-500">예상 환불 금액</span>
              <span class="text-lg font-bold <%= @booking.cancellation_refund_amount > 0 ? 'text-green-700' : 'text-red-500' %>">
                <%= number_with_delimiter(@booking.cancellation_refund_amount) %>원
              </span>
            </div>
          </div>

          <!-- Cancel Button -->
          <%= button_to cancel_booking_path(@booking), method: :patch,
              data: { confirm: "예약을 취소하시겠습니까?\n\n환불 금액: #{number_with_delimiter(@booking.cancellation_refund_amount)}원\n적용 정책: #{@booking.cancellation_policy_label}" },
              class: "w-full flex items-center justify-center gap-2 bg-red-500 text-white px-6 py-3.5 rounded-2xl font-bold text-sm hover:bg-red-600 transition-colors cursor-pointer" do %>
            <%= render "shared/icon", name: "x", size: 16, css: "text-white" %>
            예약 취소하기
          <% end %>
        </div>
      <% elsif @booking.status.start_with?("cancelled") %>
        <div class="px-8 py-6 bg-red-50/50">
          <div class="flex items-center gap-3">
            <%= render "shared/icon", name: "info", size: 16, css: "text-red-400 shrink-0" %>
            <div>
              <p class="text-sm font-bold text-red-600">이 예약은 취소되었습니다.</p>
              <% if @booking.cancel_reason.present? %>
                <p class="text-xs text-red-400 mt-1">사유: <%= @booking.cancel_reason %></p>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

    </div>

    <!-- Bottom Actions -->
    <div class="mt-6 flex items-center justify-between">
      <%= link_to bookings_path, class: "flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-800 font-medium transition-colors" do %>
        <%= render "shared/icon", name: "arrow-left", size: 16 %>
        목록으로
      <% end %>
      <%= link_to property_path(@booking.property), class: "flex items-center gap-1.5 text-sm text-green-700 hover:text-green-800 font-bold transition-colors" do %>
        숙소 상세보기
        <%= render "shared/icon", name: "arrow-right", size: 16, css: "text-green-700" %>
      <% end %>
    </div>

  </div>
</div>
