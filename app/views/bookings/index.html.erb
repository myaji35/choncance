<div class="bg-slate-50 min-h-screen py-12">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="flex items-center justify-between mb-10">
      <div>
        <div class="flex items-center gap-2 mb-1">
          <%= render "shared/icon", name: "calendar", size: 22, css: "text-green-700" %>
          <h1 class="text-2xl font-bold text-slate-900 tracking-tight">내 예약 내역</h1>
        </div>
        <p class="text-slate-500 text-sm pl-8">예약 확인 및 취소를 관리할 수 있습니다.</p>
      </div>
      <%= link_to properties_path, class: "flex items-center gap-2 bg-green-700 text-white px-5 py-2.5 rounded-xl text-sm font-bold hover:bg-green-800 transition-colors shadow-sm" do %>
        <%= render "shared/icon", name: "compass", size: 16, css: "text-white" %>
        숙소 탐색
      <% end %>
    </div>

    <% if notice.present? %>
      <div class="mb-6 flex items-center gap-3 p-4 bg-green-50 border border-green-100 text-green-700 text-sm rounded-2xl">
        <%= render "shared/icon", name: "check-circle", size: 16, css: "text-green-500 shrink-0" %>
        <%= notice %>
      </div>
    <% end %>

    <% if alert.present? %>
      <div class="mb-6 flex items-center gap-3 p-4 bg-red-50 border border-red-100 text-red-700 text-sm rounded-2xl">
        <%= render "shared/icon", name: "alert-circle", size: 16, css: "text-red-500 shrink-0" %>
        <%= alert %>
      </div>
    <% end %>

    <% if @bookings.empty? %>
      <!-- Empty State -->
      <div class="bg-white border-2 border-dashed border-slate-200 py-20 px-8 text-center rounded-3xl">
        <%= render "shared/icon", name: "inbox", size: 48, css: "text-slate-200 mx-auto mb-4" %>
        <p class="text-slate-400 font-medium mb-1">아직 예약된 내역이 없습니다.</p>
        <p class="text-slate-400 text-sm mb-6">지금 바로 촌캉스를 떠나볼까요?</p>
        <%= link_to properties_path, class: "inline-flex items-center gap-2 bg-slate-900 text-white px-6 py-3 rounded-xl font-bold hover:bg-slate-700 transition-colors text-sm" do %>
          <%= render "shared/icon", name: "compass", size: 16, css: "text-white" %>
          숙소 둘러보기
        <% end %>
      </div>
    <% else %>

      <!-- Upcoming Bookings -->
      <% if @upcoming.any? %>
        <div class="mb-10">
          <h2 class="flex items-center gap-2 text-base font-bold text-slate-900 mb-5">
            <%= render "shared/icon", name: "clock", size: 16, css: "text-green-600" %>
            다가오는 예약 (<%= @upcoming.size %>건)
          </h2>
          <div class="space-y-4">
            <% @upcoming.each do |booking| %>
              <%= link_to booking_path(booking), class: "block bg-white border border-green-100 rounded-2xl shadow-sm hover:shadow-md transition-shadow overflow-hidden" do %>
                <div class="flex items-center gap-5 px-6 py-5">
                  <!-- Icon -->
                  <div class="w-14 h-14 bg-green-50 rounded-2xl flex items-center justify-center shrink-0">
                    <%= render "shared/icon", name: "calendar", size: 24, css: "text-green-600" %>
                  </div>
                  <!-- Info -->
                  <div class="flex-1 min-w-0">
                    <p class="font-bold text-slate-900 truncate"><%= booking.property.title %></p>
                    <p class="flex items-center gap-1 text-xs text-slate-500 mt-1">
                      <%= render "shared/icon", name: "map-pin", size: 11, css: "text-slate-400 shrink-0" %>
                      <%= booking.property.location.presence || "위치 미설정" %>
                    </p>
                    <p class="text-xs text-slate-400 mt-1">
                      <%= booking.check_in.strftime("%Y.%m.%d") %> ~ <%= booking.check_out.strftime("%Y.%m.%d") %>
                      (<%= booking.nights %>박)
                    </p>
                  </div>
                  <!-- Price & Status -->
                  <div class="text-right shrink-0">
                    <p class="text-lg font-bold text-slate-900"><%= number_with_delimiter(booking.total_price) %>원</p>
                    <span class="inline-flex items-center gap-1 bg-green-50 text-green-700 text-xs font-bold px-2.5 py-1 rounded-full mt-1">
                      <%= render "shared/icon", name: "check", size: 11 %>
                      <%= booking.status_label %>
                    </span>
                  </div>
                  <!-- Arrow -->
                  <div class="shrink-0">
                    <%= render "shared/icon", name: "chevron-right", size: 18, css: "text-slate-300" %>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Past / Cancelled Bookings -->
      <% if @past.any? %>
        <div>
          <h2 class="flex items-center gap-2 text-base font-bold text-slate-900 mb-5">
            <%= render "shared/icon", name: "clock", size: 16, css: "text-slate-400" %>
            지난 예약 (<%= @past.size %>건)
          </h2>
          <div class="space-y-3">
            <% @past.each do |booking| %>
              <%= link_to booking_path(booking), class: "block bg-white border border-slate-100 rounded-2xl shadow-sm hover:shadow-md transition-shadow overflow-hidden" do %>
                <div class="flex items-center gap-5 px-6 py-4">
                  <!-- Icon -->
                  <div class="w-12 h-12 bg-slate-50 rounded-xl flex items-center justify-center shrink-0">
                    <% if booking.status.start_with?("cancelled") %>
                      <%= render "shared/icon", name: "x", size: 20, css: "text-slate-300" %>
                    <% else %>
                      <%= render "shared/icon", name: "check-circle", size: 20, css: "text-slate-300" %>
                    <% end %>
                  </div>
                  <!-- Info -->
                  <div class="flex-1 min-w-0">
                    <p class="font-semibold text-slate-600 truncate"><%= booking.property.title %></p>
                    <p class="text-xs text-slate-400 mt-1">
                      <%= booking.check_in.strftime("%Y.%m.%d") %> ~ <%= booking.check_out.strftime("%Y.%m.%d") %>
                    </p>
                  </div>
                  <!-- Status -->
                  <div class="text-right shrink-0">
                    <p class="text-sm font-bold text-slate-500"><%= number_with_delimiter(booking.total_price) %>원</p>
                    <% if booking.status.start_with?("cancelled") %>
                      <span class="inline-flex items-center gap-1 bg-red-50 text-red-500 text-xs font-bold px-2.5 py-1 rounded-full mt-1">
                        <%= booking.status_label %>
                      </span>
                    <% else %>
                      <span class="inline-flex items-center gap-1 bg-slate-50 text-slate-500 text-xs font-bold px-2.5 py-1 rounded-full mt-1">
                        <%= booking.status_label %>
                      </span>
                    <% end %>
                  </div>
                  <div class="shrink-0">
                    <%= render "shared/icon", name: "chevron-right", size: 18, css: "text-slate-300" %>
                  </div>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>

    <% end %>

  </div>
</div>
