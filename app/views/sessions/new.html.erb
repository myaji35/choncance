<div class="min-h-screen bg-slate-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-md">
    <h2 class="text-center text-4xl font-extrabold text-slate-900 tracking-tight font-outfit">
      반가워요! 🌾
    </h2>
    <p class="mt-2 text-center text-sm text-slate-600">
      로그인하고 당신만의 촌캉스를 완성해보세요.
    </p>
  </div>

  <div class="mt-8 sm:mx-auto sm:w-full sm:max-w-md">
    <div class="bg-white py-12 px-10 shadow-2xl rounded-[3rem] border border-slate-100">
      <% if alert %>
        <div class="mb-6 p-4 bg-rose-50 border border-rose-100 text-rose-700 text-sm rounded-2xl">
          <%= alert %>
        </div>
      <% end %>

      <%= form_with url: session_path, class: "space-y-6" do |f| %>
        <div>
          <%= f.label :email_address, "이메일 주소", class: "block text-xs font-bold text-slate-900 uppercase tracking-widest mb-2" %>
          <%= f.email_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "example@choncance.com", 
              class: "appearance-none block w-full px-5 py-4 border border-slate-200 rounded-2xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-green-500 focus:border-green-500 text-sm transition" %>
        </div>

        <div>
          <%= f.label :password, "비밀번호", class: "block text-xs font-bold text-slate-900 uppercase tracking-widest mb-2" %>
          <%= f.password_field :password, required: true, autocomplete: "current-password", placeholder: "••••••••", 
              class: "appearance-none block w-full px-5 py-4 border border-slate-200 rounded-2xl shadow-sm placeholder-slate-400 focus:outline-none focus:ring-green-500 focus:border-green-500 text-sm transition" %>
        </div>

        <div class="flex items-center justify-between">
          <div class="flex items-center">
            <input id="remember_me" name="remember_me" type="checkbox" class="h-4 w-4 text-green-700 focus:ring-green-500 border-slate-300 rounded-md">
            <label for="remember_me" class="ml-2 block text-sm text-slate-500">로그인 유지</label>
          </div>

          <div class="text-sm">
            <%= link_to "비밀번호를 잊으셨나요?", new_password_path, class: "font-medium text-green-700 hover:text-green-800" %>
          </div>
        </div>

        <div>
          <%= f.submit "로그인", class: "w-full flex justify-center py-4 px-4 border border-transparent rounded-2xl shadow-lg text-lg font-bold text-white bg-green-700 hover:bg-green-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-all transform active:scale-95" %>
        </div>
      <% end %>

      <div class="mt-10">
        <div class="relative">
          <div class="absolute inset-0 flex items-center">
            <div class="w-full border-t border-slate-200"></div>
          </div>
          <div class="relative flex justify-center text-sm">
            <span class="px-2 bg-white text-slate-400">간편하게 시작하기</span>
          </div>
        </div>

        <div class="mt-6">
          <button class="w-full flex items-center justify-center py-4 border border-slate-200 rounded-2xl shadow-sm bg-white text-sm font-bold text-slate-700 hover:bg-slate-50 transition">
             <span class="mr-3 text-xl">💬</span> 카카오로 시작하기
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
