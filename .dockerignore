# VINTEE Next.js Docker ignore

# Git
.git/
.gitignore

# 환경변수 (서버에서 주입)
.env
.env.*
!.env.example

# 빌드 산출물 (Docker 내부에서 생성)
node_modules/
.next/
npm-debug.log*

# 테스트
tests/
test-results/
playwright-report/
*.spec.ts

# 문서/스크립트
docs/
scripts/
deploy.sh
*.md
!README.md

# Rails 관련 파일 (공존하지만 Node 빌드 불필요)
app/
config/
db/
lib/
log/
tmp/
vendor/
Gemfile
Gemfile.lock
Rakefile
config.ru
*.rb
.bundle/
.kamal/

# macOS
.DS_Store
._*

# IDE
.vscode/
.idea/
*.swp

# CI
.github/

# 기타
test-results/
playwright-report/
