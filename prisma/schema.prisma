// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  clerkId       String?   @unique
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  accounts      Account[]
  sessions      Session[]
  kakaoId       String?   @unique
  provider      String?   @default("email")
  role          String    @default("USER")

  // Credit System
  credits       Int       @default(0)
  totalEarned   Int       @default(0)

  hostProfile   HostProfile?
  pmProjects    PMProject[]
  bookings      Booking[]
  wishlists     Wishlist[]
  reviews       Review[]
  notifications Notification[]
  creditHistory CreditHistory[]
}

model HostProfile {
  id              String @id @default(cuid())
  userId          String @unique
  user            User   @relation(fields: [userId], references: [id])
  businessNumber  String
  contact         String
  status          String @default("PENDING")

  properties      Property[]
  experiences     Experience[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// PM Tools Models
// ============================================

model PMProject {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  prds        PRD[]
  epics       Epic[]
  stories     Story[]
  changeLogs  ChangeLog[]

  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id])
}

model PRD {
  id               String   @id @default(cuid())
  title            String
  type             String
  goals            String   // JSON stored as String
  background       String
  uiGoals          String?  // JSON stored as String
  technicalAssum   String?  // JSON stored as String
  status           String   @default("draft")

  projectId        String
  project          PMProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  requirements     Requirement[]
  epics            Epic[]
  changeLogs       ChangeLog[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Requirement {
  id          String   @id @default(cuid())
  prefix      String
  number      Int
  description String
  type        String

  prdId       String
  prd         PRD      @relation(fields: [prdId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Epic {
  id          String   @id @default(cuid())
  number      Int
  title       String
  goal        String
  type        String   @default("greenfield")
  status      String   @default("pending")

  projectId   String?
  project     PMProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  prdId       String?
  prd         PRD?     @relation(fields: [prdId], references: [id], onDelete: Cascade)

  stories     Story[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Story {
  id                String   @id @default(cuid())
  epicNumber        Int
  storyNumber       Int
  title             String
  userType          String
  action            String
  benefit           String
  type              String   @default("greenfield")
  status            String   @default("pending")

  epicId            String
  epic              Epic     @relation(fields: [epicId], references: [id], onDelete: Cascade)

  projectId         String?
  project           PMProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  acceptanceCriteria AcceptanceCriteria[]
  integrationVerification IntegrationVerification[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AcceptanceCriteria {
  id          String   @id @default(cuid())
  number      Int
  criteria    String

  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IntegrationVerification {
  id          String   @id @default(cuid())
  number      Int
  description String

  storyId     String
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChangeLog {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  version     String
  description String
  author      String

  projectId   String?
  project     PMProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  prdId       String?
  prd         PRD?     @relation(fields: [prdId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CourseCorrection {
  id                String   @id @default(cuid())
  title             String
  changeTrigger     String
  impactAnalysis    String   // JSON stored as String
  proposedChanges   String   // JSON stored as String
  status            String   @default("draft")

  projectId         String

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================
// ChonCance Core Models
// ============================================

model Tag {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String   // VIEW | ACTIVITY | FACILITY | VIBE
  icon        String?
  description String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  properties  Property[]
}

model Property {
  id            String   @id @default(cuid())
  hostId        String
  host          HostProfile @relation(fields: [hostId], references: [id])

  name          String
  description   String
  address       String
  location      String   // JSON stored as String: { lat, lng }
  province      String?
  city          String?

  pricePerNight Float
  discountRate  Int?
  discountedPrice Float?
  maxGuests     Int
  allowsPets    Boolean  @default(false)

  images        String   @default("[]") // JSON array stored as String
  thumbnailUrl  String?

  hostStory     String?
  amenities     String   @default("[]") // JSON array stored as String
  rules         String?

  checkInTime   String   @default("15:00")
  checkOutTime  String   @default("11:00")
  minNights     Int      @default(1)
  maxNights     Int      @default(30)

  status        String   @default("PENDING")

  tags          Tag[]

  bookings      Booking[]
  calendar      Calendar[]
  wishlists     Wishlist[]
  reviews       Review[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([province])
  @@index([city])
  @@index([pricePerNight])
  @@index([maxGuests])
}

model Experience {
  id                String   @id @default(cuid())
  propertyId        String
  hostId            String
  host              HostProfile @relation(fields: [hostId], references: [id])

  name              String
  description       String
  price             Float
  duration          Int
  maxParticipants   Int

  images            String   @default("[]") // JSON array stored as String

  availableDays     String   @default("[]") // JSON array stored as String
  availableTimes    String   @default("[]") // JSON array stored as String

  status            String   @default("active")

  bookingItems      BookingItem[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================
// Booking System Models
// ============================================

model Booking {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id])
  propertyId          String
  property            Property @relation(fields: [propertyId], references: [id])

  checkIn             DateTime
  checkOut            DateTime
  guests              Int

  nightlyRate         Float
  numberOfNights      Int
  accommodationTotal  Float
  experiencesTotal    Float    @default(0)
  serviceFee          Float
  totalAmount         Float

  status              String   @default("PENDING")

  guestName           String
  guestPhone          String
  guestEmail          String

  specialRequests     String?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  confirmedAt         DateTime?
  cancelledAt         DateTime?
  cancellationReason  String?
  rejectedAt          DateTime?
  rejectionReason     String?

  items               BookingItem[]
  payment             Payment?
  review              Review?

  @@index([userId, status])
  @@index([propertyId, checkIn, checkOut])
}

model BookingItem {
  id            String   @id @default(cuid())
  bookingId     String
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  experienceId  String
  experience    Experience @relation(fields: [experienceId], references: [id])

  date          DateTime
  time          String
  quantity      Int
  price         Float
  totalPrice    Float

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Calendar {
  id            String   @id @default(cuid())
  propertyId    String
  property      Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  date          DateTime
  available     Boolean  @default(true)
  priceOverride Float?
  reason        String?
  minNights     Int?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([propertyId, date])
  @@index([propertyId, date])
}

model Payment {
  id            String   @id @default(cuid())
  bookingId     String   @unique
  booking       Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  amount        Float
  currency      String   @default("KRW")
  status        String   @default("READY")
  paymentMethod String?

  paymentKey    String?
  orderId       String   @unique
  orderName     String

  requestedAt   DateTime @default(now())
  approvedAt    DateTime?
  cancelledAt   DateTime?
  refundedAt    DateTime?

  refundAmount  Float?
  refundReason  String?

  transactions  PaymentTransaction[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([orderId])
}

model PaymentTransaction {
  id          String   @id @default(cuid())
  paymentId   String
  payment     Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  externalId  String?
  type        String
  amount      Float
  status      String
  method      String?
  metadata    String?  // JSON stored as String

  createdAt   DateTime @default(now())
}

// ============================================
// Wishlist Model
// ============================================

model Wishlist {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt  DateTime @default(now())

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

// ============================================
// Review Model
// ============================================

model Review {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookingId   String   @unique
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  rating      Int
  content     String
  images      String   @default("[]") // JSON array stored as String

  snsShareConsent Boolean  @default(false)
  snsShared       Boolean  @default(false)
  snsSharedAt     DateTime?
  creditAwarded   Boolean  @default(false)

  hostReply   String?
  repliedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([propertyId])
  @@index([userId])
  @@index([rating])
  @@index([snsShareConsent])
}

// ============================================
// Notification Model
// ============================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   // NotificationType enum values
  title     String
  message   String
  link      String?

  read      Boolean  @default(false)
  readAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

// ============================================
// Credit System
// ============================================

model CreditHistory {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount      Int
  type        String   // CreditType enum values
  description String?

  reviewId    String?
  bookingId   String?

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ============================================
// SNS Integration
// ============================================

model SNSAccount {
  id            String   @id @default(cuid())
  platform      String   // SNSPlatform enum values
  accountName   String
  accountUrl    String
  accessToken   String?
  refreshToken  String?
  isActive      Boolean  @default(true)

  followerCount Int?
  lastPostAt    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([platform, accountName])
  @@index([platform])
  @@index([isActive])
}

// ============================================
// SNS Post Tracking
// ============================================

model SNSPost {
  id          String   @id @default(cuid())
  platform    String   // SNSPlatform enum values
  postUrl     String
  postId      String?

  content     String
  images      String   @default("[]") // JSON array stored as String

  reviewId    String
  propertyId  String

  likes       Int      @default(0)
  comments    Int      @default(0)
  shares      Int      @default(0)

  publishedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([reviewId])
  @@index([platform])
  @@index([publishedAt])
}

// ============================================
// Chatbot LLM Settings
// ============================================

model ChatbotSettings {
  id          String   @id @default("default")
  llmProvider String   @default("GEMINI")
  geminiApiKey String?
  openaiApiKey String?

  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

// ============================================================
// VINTEE Intelligence Pipeline (VIP)
// ============================================================

model RawCrawlResult {
  id           String   @id @default(cuid())
  source       String
  sourceId     String?
  name         String
  address      String?
  phone        String?
  lat          Float?
  lng          Float?
  sourceRating Float?
  reviewCount  Int      @default(0)
  rawReviews   String?  // JSON stored as String
  amenities    String   @default("[]") // JSON array stored as String
  extraData    String?  // JSON stored as String
  crawledAt    DateTime @default(now())
  isProcessed  Boolean  @default(false)

  @@map("raw_crawl_results")
  @@index([source])
  @@index([isProcessed])
  @@index([crawledAt])
}

model PropertyIntelligence {
  id             String   @id @default(cuid())
  name           String
  address        String?
  region         String?
  subregion      String?
  lat            Float?
  lng            Float?
  phone          String?

  avgRating      Float?
  totalReviews   Int?
  sentimentScore Float?
  themeScore     Float?
  recencyScore   Float?
  vinteeScore    Float?

  autoTags       String   @default("[]") // JSON array stored as String
  isRecruited    Boolean  @default(false)
  recruitNote    String?
  recruitedAt    DateTime?

  naverId        String?
  kakaoId        String?
  yanoljaId      String?
  yeogiId        String?
  airbnbId       String?

  thumbnailUrl   String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("property_intelligence")
  @@index([region])
  @@index([vinteeScore])
  @@index([isRecruited])
}

model CrawlJobLog {
  id               String    @id @default(cuid())
  source           String
  region           String?
  status           String
  totalCrawled     Int       @default(0)
  newProperties    Int       @default(0)
  updatedProperties Int      @default(0)
  errorCount       Int       @default(0)
  errorDetails     String?   // JSON stored as String
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  durationSeconds  Int?

  @@map("crawl_job_logs")
  @@index([source])
  @@index([status])
  @@index([startedAt])
}
