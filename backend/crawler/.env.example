# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname

# Anthropic (Claude Haiku for NLP)
ANTHROPIC_API_KEY=sk-ant-...

# Crawl Schedule (cron syntax)
CRAWL_SCHEDULE_FULL=0 2 * * 0
CRAWL_SCHEDULE_INCREMENTAL=0 3 * * *

# Rate Limiting
CRAWL_DELAY_MIN=3
CRAWL_DELAY_MAX=5
CRAWL_MAX_REQUESTS_PER_HOUR=300

# Logging
LOG_LEVEL=INFO
