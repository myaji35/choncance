generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── 사용자 ───
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      String   @default("GUEST") // GUEST | HOST | ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties Property[]
  bookings   Booking[]
  reviews    Review[]
  credits    CreditHistory[]
}

// ─── 숙소 ───
model Property {
  id            String  @id @default(cuid())
  title         String
  description   String?
  location      String
  address       String?
  latitude      Float?
  longitude     Float?
  phone         String?
  thumbnailUrl  String?
  pricePerNight Int?
  maxGuests     Int     @default(4)
  amenities     String  @default("[]") // JSON array
  status        String  @default("draft") // draft | active | inactive
  source        String  @default("direct") // direct | uploaded
  uploadedBy    String? // "System Auto-Collection" 등

  // ─── GEO 최적화 필드 ───
  checkinTime       String? // "15:00"
  checkoutTime      String? // "11:00"
  highlights        String  @default("[]") // JSON: ["논뷰 전망", "바비큐"]
  nearbyAttractions String  @default("[]") // JSON: [{"name":"현충사","distance":"차로 15분"}]
  bestSeason        String? // "가을" | "사계절" 등
  hostIntro         String? // 호스트 자기소개 (E-E-A-T)
  uniqueExperience  String? // "감귤 따기, 한복 입기"
  petsAllowed       Boolean @default(false)
  numberOfRooms     Int     @default(1)

  hostId    String
  host      User       @relation(fields: [hostId], references: [id])
  bookings  Booking[]
  reviews   Review[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// ─── 예약 ───
model Booking {
  id         String @id @default(cuid())
  status     String @default("PENDING") // PENDING | CONFIRMED | COMPLETED | CANCELLED
  checkIn    DateTime
  checkOut   DateTime
  guestCount Int    @default(1)
  totalPrice Int    @default(0)
  message    String? // 호스트에게 전하는 메시지

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  review     Review?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── 리뷰 ───
model Review {
  id              String   @id @default(cuid())
  rating          Int      // 1-5
  content         String
  images          String   @default("[]") // JSON array of URLs
  snsShareConsent Boolean  @default(false)
  snsShared       Boolean  @default(false)
  snsSharedAt     DateTime?
  creditAwarded   Boolean  @default(false)
  hostReply       String?
  repliedAt       DateTime?

  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── 크레딧 이력 ───
model CreditHistory {
  id     String @id @default(cuid())
  type   String // EARNED_REVIEW_SNS | SPENT_BOOKING 등
  amount Int
  memo   String?

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
