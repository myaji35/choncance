generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── 사용자 ───
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?  // OAuth 사용자는 null
  name      String
  phone     String?
  image     String?  // 프로필 이미지 (OAuth)
  provider  String   @default("credentials") // credentials | google | kakao 등
  providerId String? // OAuth 제공자의 사용자 ID
  role      String   @default("GUEST") // GUEST | HOST | ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties Property[]
  bookings   Booking[]
  reviews    Review[]
  credits    CreditHistory[]

  @@index([provider, providerId])
}

// ─── 숙소 ───
model Property {
  id            String  @id @default(cuid())
  title         String
  description   String?
  location      String
  address       String?
  latitude      Float?
  longitude     Float?
  phone         String?
  thumbnailUrl  String?
  pricePerNight Int?
  maxGuests     Int     @default(4)
  amenities     String  @default("[]") // JSON array
  status        String  @default("draft") // draft | active | inactive
  source        String  @default("direct") // direct | uploaded
  uploadedBy    String? // "System Auto-Collection" 등

  // ─── GEO 최적화 필드 ───
  checkinTime       String? // "15:00"
  checkoutTime      String? // "11:00"
  highlights        String  @default("[]") // JSON: ["논뷰 전망", "바비큐"]
  nearbyAttractions String  @default("[]") // JSON: [{"name":"현충사","distance":"차로 15분"}]
  bestSeason        String? // "가을" | "사계절" 등
  hostIntro         String? // 호스트 자기소개 (E-E-A-T)
  uniqueExperience  String? // "감귤 따기, 한복 입기"
  petsAllowed       Boolean @default(false)
  numberOfRooms     Int     @default(1)

  // ─── GraphRAG 확장 ───
  regionId String?
  region   Region? @relation(fields: [regionId], references: [id])

  hostId    String
  host      User       @relation(fields: [hostId], references: [id])
  bookings  Booking[]
  reviews   Review[]
  tags      PropertyTag[]
  attractions PropertyAttraction[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// ─── 예약 ───
model Booking {
  id         String @id @default(cuid())
  status     String @default("PENDING") // PENDING | CONFIRMED | COMPLETED | CANCELLED
  checkIn    DateTime
  checkOut   DateTime
  guestCount Int    @default(1)
  totalPrice Int    @default(0)
  message    String? // 호스트에게 전하는 메시지

  userId     String
  user       User     @relation(fields: [userId], references: [id])
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  review     Review?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── 리뷰 ───
model Review {
  id              String   @id @default(cuid())
  rating          Int      // 1-5
  content         String
  images          String   @default("[]") // JSON array of URLs
  snsShareConsent Boolean  @default(false)
  snsShared       Boolean  @default(false)
  snsSharedAt     DateTime?
  creditAwarded   Boolean  @default(false)
  hostReply       String?
  repliedAt       DateTime?

  bookingId  String   @unique
  booking    Booking  @relation(fields: [bookingId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  tags       ReviewTag[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── GraphRAG: 태그 (Theme/Feature/Mood/Activity/Audience/Season) ───
model Tag {
  id        String   @id @default(cuid())
  type      String   // theme | feature | mood | activity | audience | season
  name      String   // "한옥", "반려동물OK", "조용함", "가을"
  slug      String   @unique
  embedding Bytes?   // text-embedding-3-small (1536 dim, Float32 packed)
  createdAt DateTime @default(now())

  properties PropertyTag[]
  reviews    ReviewTag[]

  @@index([type])
}

model PropertyTag {
  propertyId String
  tagId      String
  score      Float    @default(1.0) // 0-1 관련도
  source     String   @default("manual") // manual | auto_rule | auto_llm | auto_review

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([propertyId, tagId])
  @@index([tagId])
}

model ReviewTag {
  reviewId  String
  tagId     String
  sentiment String @default("neutral") // positive | neutral | negative

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([reviewId, tagId])
  @@index([tagId])
}

// ─── GraphRAG: 지역 계층 ───
model Region {
  id       String   @id @default(cuid())
  name     String   // "충남 아산"
  slug     String   @unique
  level    Int      // 1: 시도, 2: 시군구, 3: 읍면동
  parentId String?
  parent   Region?  @relation("RegionHierarchy", fields: [parentId], references: [id])
  children Region[] @relation("RegionHierarchy")

  properties Property[]

  @@index([parentId])
}

// ─── GraphRAG: 관광지 ───
model Attraction {
  id        String  @id @default(cuid())
  name      String
  latitude  Float
  longitude Float
  category  String? // 자연 | 문화 | 역사 | 체험
  createdAt DateTime @default(now())

  properties PropertyAttraction[]
}

model PropertyAttraction {
  propertyId   String
  attractionId String
  distanceKm   Float
  travelTime   String? // "차로 15분"

  property   Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  attraction Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)

  @@id([propertyId, attractionId])
  @@index([attractionId])
}

// ─── 크레딧 이력 ───
model CreditHistory {
  id     String @id @default(cuid())
  type   String // EARNED_REVIEW_SNS | SPENT_BOOKING 등
  amount Int
  memo   String?

  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}
